{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}",
          "retainedFileCountLimit": 30,
          "shared": true,
          "flushToDiskInterval": "00:00:01"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=ChineseRaffle;Integrated Security=SSPI;Persist Security Info=False;TrustServerCertificate=True",
    "SchoolConnection": "Server=srv2\\pupils;Database=ChineseRaffle_216197806;Integrated Security=SSPI;Persist Security Info=False;TrustServerCertificate=True"
  },

  "RateLimiting": {
    "RequestLimit": 100,
    "TimeWindowMinutes": 1
  },

  "Redis": {
    "Host": "redis",
    "Port": 6379,
    "Password": "",
    "InstanceName": "ChineseRaffleApi:"
  },

  "Kafka": {
    "BootstrapServers": "kafka:9092",
    "TopicName": "chinese-raffle-events",
    "Producer": {
      "ClientId": "chinese-raffle-api",
      "Acks": "All",
      "EnableIdempotence": true,
      "MessageSendMaxRetries": 3,
      "RetryBackoffMs": 250,
      "LingerMs": 5,
      "CompressionType": "None",
      "SocketTimeoutMs": 10000
    }
  },

  "CacheSettings": {
    "GiftByIdTtlSeconds": 60
  },

  "JwtSettings": {
    "SecretKey": "YourSuperSecretKeyForJWTTokenGeneration123456789",
    "Issuer": "http://localhost:7101",
    "Audience": "http://localhost:4200",
    "ExpiryMinutes": 120
  }
}
